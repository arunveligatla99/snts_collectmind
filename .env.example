# OAuth2 / authentication
OAUTH2_ISSUER_URL=http://mock-issuer:8088
OAUTH2_AUDIENCE=collectmind-api

# SLM profile (gpu | cpu) — feature 002 brings vLLM up; feature 001 foundation does not.
SLM_PROFILE=cpu

# Logical-time scaling per FR-009a; tests use 3600.0 to make a 1h window complete in 1 wall second.
TIME_ACCELERATION_FACTOR=1.0

# Observability
OTLP_ENDPOINT=http://tempo:4317
LOG_LEVEL=INFO

# Storage
POSTGRES_DSN=postgresql://collectmind:localdev@postgres-timescale:5432/collectmind
REDIS_URL=redis://redis:6379/0

# Event transport
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# SLM weight cache (host path mounted into the SLM container)
SLM_WEIGHTS_PATH=./models/weights

# Code-signing key (development; KMS in deployed environments)
SIGNING_KEY_PATH=./models/dev-signing.key
