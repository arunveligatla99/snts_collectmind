{
  "name": "collectmind-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/bundle_content.mjs && vite",
    "prebuild": "node scripts/bundle_content.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "gen:types": "openapi-typescript ../contracts/openapi/orchestration-api.v1.yaml -o src/api/types/orchestration.d.ts && openapi-typescript ../contracts/openapi/query-api.v1.yaml -o src/api/types/query.d.ts && openapi-typescript ../contracts/openapi/audit-admin.v1.yaml -o src/api/types/audit-admin.d.ts",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tanstack/react-query": "5.62.7",
    "@tremor/react": "3.18.7",
    "clsx": "2.1.1",
    "mermaid": "11.4.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.28.1",
    "tailwind-merge": "2.5.5",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "22.10.2",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "2.1.8",
    "autoprefixer": "10.4.20",
    "jsdom": "25.0.1",
    "openapi-typescript": "7.4.4",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2",
    "vite": "6.0.5",
    "vitest": "2.1.8"
  }
}
